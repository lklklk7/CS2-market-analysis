# ── Skin watchlist ────────────────────────────────────────────────────────────
# Comma-separated; use the exact Steam market hash name including wear bracket
SKIN_LIST=AK-47 | Redline (Field-Tested),AWP | Asiimov (Battle-Scarred),Karambit | Fade (Factory New)

# ── AI provider (at least one required) ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1   # override for DeepSeek / custom
OPENAI_MODEL=gpt-4o

# ── Notifications (at least one required) ────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Optional data-source API keys ─────────────────────────────────────────────
CSFLOAT_API_KEY=
SKINPORT_API_KEY=

# ── Schedule ──────────────────────────────────────────────────────────────────
# Cron expression for local --schedule mode (default: 09:00 UTC daily)
SCHEDULE_CRON=0 9 * * *

# ── Misc ──────────────────────────────────────────────────────────────────────
# Steam app ID for CS2
STEAM_APP_ID=730
# Currency: 1=USD 3=EUR 5=RUB
STEAM_CURRENCY=1
# Cache TTL in seconds (default 24 h)
CACHE_TTL=86400
# Debug logging
DEBUG=false
